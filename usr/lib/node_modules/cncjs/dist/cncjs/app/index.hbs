<link href="/1b2c6043/main.css" rel="stylesheet">
</head>

<body>
<div id="loading"></div>

<script>
window.addEventListener('load',function(){
  setTimeout(function(){
    var s=document.createElement('style');
    s.innerHTML=`

html,body,#app,.workspace,.main,.content,.container,.container-fluid,
.react-grid-item,.react-grid-layout,.react-grid-placeholder{
  background:#121212!important;
  color:#e0e0e0!important;
}

.panel,.card,.widget,.panel-body,.panel-default,
[class*="widget"],
[class*="Widget"],
[class*="widget-title"],
[class*="Widget__widget-title"],
[class*="index__widget-title"],
[class*="primary-container"],
[class*="secondary-container"]{
  background:#1a1a1a!important;
  background-color:#1a1a1a!important;
  color:#e0e0e0!important;
  border-color:#333!important;
}

[class*="widget-title"]{
  background:#151515!important;
}

input,textarea,select,button{
  background:#2a2a2a!important;
  color:#fff!important;
  border:1px solid #333!important;
}

canvas{
  background:#0f0f0f!important;
}

svg,img[src^="data:image/svg+xml"],img[src$=".svg"]{
  filter:invert(1) hue-rotate(180deg)!important;
}

svg[data-no-invert],svg[fill="none"]{
  filter:none!important;
}

/* Console containers */
[class*="Console"],
[class*="console"]{
  background:#050505!important;
  background-color:#050505!important;
  color:#e6e6e6!important;
}

/* xterm common layers */
.xterm,
.xterm-viewport,
.xterm-screen,
.xterm-helpers,
.xterm-rows{
  background:#050505!important;
  background-color:#050505!important;
  color:#e6e6e6!important;
}

.xterm *,
.xterm-rows *,
.xterm-rows span,
.xterm-rows span span{
  color:#e6e6e6!important;
  background-color:transparent!important;
}

.xterm-cursor,
.xterm-cursor-layer{
  background:#e6e6e6!important;
  color:#050505!important;
}

.workspace > div{
  background:transparent!important;
}


/* ================= SETTINGS / FORM HARD FIX ================= */

.Select-control,
.Select-menu-outer,
.Select-menu,
.Select-option,
.Select-value,
.Select-value-label,
.Select-placeholder,
.modal,
.modal-dialog,
.modal-content,
.modal-header,
.modal-body,
.modal-footer,
.tab-content,
.tab-pane,
.nav,
.nav-tabs,
.list-group,
.list-group-item,
.table,
.table tbody,
.table tr,
.table td,
.table th {
  background:#1a1a1a!important;
  background-color:#1a1a1a!important;
  color:#e0e0e0!important;
  border-color:#333!important;
}

.Select-value-label,
.Select-option,
.Select-control div,
.Select span,
.Select div,
.control-label,
label,
.checkbox label,
.radio label {
  color:#e0e0e0!important;
}

[style*="color: rgb(51, 51, 51)"],
[style*="color: rgb(34, 34, 34)"],
[style*="color: rgb(0, 0, 0)"] {
  color:#e0e0e0!important;
}

.Select.is-disabled .Select-control,
.Select.is-disabled .Select-value-label {
  background:#151515!important;
  color:#888!important;
}

.Select-arrow-zone,
.Select-arrow {
  color:#e0e0e0!important;
  border-top-color:#e0e0e0!important;
}

`;
    document.head.appendChild(s);

    function forceConsoleColours(){
      document.querySelectorAll('[class*="Console"],[class*="console"],.xterm,.xterm *,.xterm-rows,.xterm-rows *').forEach(function(el){
        el.style.color = '#e6e6e6';
      });

      document.querySelectorAll('[class*="Console"],[class*="console"],.xterm,.xterm-viewport,.xterm-screen,.xterm-helpers,.xterm-rows').forEach(function(el){
        el.style.backgroundColor = '#050505';
      });
    }


    forceConsoleColours();
    setInterval(forceConsoleColours,1000);

    function forceSettingsColours(){
      document.querySelectorAll(
        'body,#app,[class*="App__main"],[class*="App__content"],' +
        '[class*="App__content"],[class*="Settings"],[class*="settings"],' +
        '.modal,.modal-dialog,.modal-content,.modal-header,.modal-body,.modal-footer,' +
        '.form-group,.form-control,.Select,.Select-control,.Select-menu-outer,.Select-menu,.Select-option,' +
        '.tab-content,.tab-pane,.nav,.nav-tabs,.list-group,.list-group-item,.table,.table *'
      ).forEach(function(el){
        el.style.backgroundColor = '#1a1a1a';
        el.style.color = '#e0e0e0';
        el.style.borderColor = '#333';
      });

      document.querySelectorAll(
        'label,.control-label,.checkbox label,.radio label,.help-block,' +
        '.Select-value-label,.Select-placeholder,.Select-option,.Select-control div,.Select span,.Select div,' +
        '[class*="Settings"] a,[class*="settings"] a,' +
        '[class*="Settings"] li,[class*="settings"] li,' +
        '[class*="Settings"] ul,[class*="settings"] ul'
      ).forEach(function(el){
        el.style.color = '#e0e0e0';
      });

      document.querySelectorAll(
        '[class*="Settings"],[class*="settings"],' +
        '[class*="Settings"] *,[class*="settings"] *'
      ).forEach(function(el){
        el.style.backgroundColor = '#1a1a1a';
        el.style.color = '#e0e0e0';
        el.style.borderColor = '#333';
      });
    }


    forceSettingsColours();
    setInterval(forceSettingsColours,1000);

    function forceVisualizerWorkflowFix(){
      document.querySelectorAll(
        '.widgets\\/Visualizer\\/workflow-control__workflow-control--2gOf5 [class*="btn-group"]'
      ).forEach(function(el){
        if (el.style.backgroundColor === 'white' || el.style.backgroundColor === 'rgb(255, 255, 255)') {
          el.style.backgroundColor = '#1a1a1a';
        }
      });
    }

    forceVisualizerWorkflowFix();
    setInterval(forceVisualizerWorkflowFix,500);

  },1200);
});
</script>

</body></html>
